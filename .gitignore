# Default-deny for a public repository.
*

# Repository metadata and docs.
!.gitignore
!.gitattributes
!README.md
!package.json
!package-lock.json
!index.html
!wrangler.toml
!wrangler.worker.toml
!vite.config.ts
!tsconfig.json
!tsconfig.app.json
!tsconfig.node.json

# GitHub automation.
!.github/
!.github/**

# Public assets.
!static-public/
!static-public/_headers
!static-public/favicon.svg
!static-public/opticplan-dashboard.png

# Current application source only.
!src/
!src/main.tsx
!src/App.tsx
!src/styles.css
!src/vite-env.d.ts
!src/content/
!src/content/**
!src/lib/
!src/lib/analytics.ts
!src/lib/mission.ts
!src/lib/routing.ts
!src/lib/seo.ts
!scripts/
!scripts/postbuild.mjs
!functions/
!functions/**

# Cloudflare Worker.
!worker/
!worker/index.js

public/

# Generated and private files.
node_modules/
dist/
.wrangler/
.runtime/
.python_packages/
.codex_tmp*
.env
.env.*
*.log
*.tsbuildinfo
.preview.*
.local-*.png
.DS_Store
